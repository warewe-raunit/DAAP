# Copy this to .env and fill in your keys

# --- Required ---
OPENROUTER_API_KEY=sk-or-...

# --- Auth (strongly recommended for any public server) ---
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DAAP_API_KEY=

