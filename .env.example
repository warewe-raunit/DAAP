# ============================================================================
# DAAP environment — copy to .env and fill in your values
# ============================================================================
# cp .env.example .env

# ─── Required ────────────────────────────────────────────────────────────────
# All LLM calls are routed through OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Auth (strongly recommended for any server exposed beyond localhost) ──────
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DAAP_API_KEY=

# ─── Deployment ──────────────────────────────────────────────────────────────
# Host bind address. 127.0.0.1 = loopback only (put nginx/caddy in front).
# Set to 0.0.0.0 only for trusted private networks.
DAAP_BIND_ADDR=127.0.0.1
DAAP_PORT=8000
# Internal container port. Usually leave this as 8000.
DAAP_CONTAINER_PORT=8000
# Public origin for WebSocket URL generation when behind a reverse proxy:
# DAAP_PUBLIC_ORIGIN=https://your.domain

# ─── Optional: Mem0 memory ───────────────────────────────────────────────────
# MEM0_API_KEY=               # only needed if using Mem0 cloud instead of Qdrant
# QDRANT_HOST=qdrant          # set by docker-compose; override for external Qdrant
# QDRANT_PORT=6333

# ─── Optional: Jina Reader (improves web_fetch for JS-heavy pages) ───────────
# JINA_API_KEY=

# ─── Optional: Keywords Everywhere (keyword volume / CPC ranking) ─────────────
# KEYWORDS_EVERYWHERE_API_KEY=
